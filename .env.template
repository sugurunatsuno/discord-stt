DISCORD_TOKEN=
WHISPER_MODEL=large-v3-turbo
WHISPER_DEVICE=cpu
WHISPER_PRECISION=int8
WHISPER_LANG=ja
WHISPER_VAD_MS=600
DISCORD_TEXT_CHANNEL_ID=1
LOG_LEVEL=debug
LOG_FILE=app.log
# Discordの投稿スタイル（1で簡素表示）
POST_MINIMAL=1

# STT結果を無視するフレーズ（カンマ区切り）
# 例: 大学の大学の大学の, お母さんのお母さん, おやすみなさい おやすみなさい
STT_IGNORE_LIST=

# アーカイブ（WAVを低ビットレートで保存してWAV削除）
ARCHIVE_ENABLED=1
ARCHIVE_DIR=archive
ARCHIVE_CONTAINER=ogg
ARCHIVE_CODEC=libopus
ARCHIVE_BITRATE=16k
ARCHIVE_SR=16000
